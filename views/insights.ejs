<%- include('partials/head') %>
<main class="shell">
  <%- include('partials/nav', { page }) %>
  <section class="page">
    <header class="topbar compact">
      <div>
        <p class="eyebrow">Viral insights</p>
        <h1>Signals that help creators choose better formats and audio.</h1>
      </div>
    </header>

    <section class="two-column">
      <article class="panel">
        <div class="panel-heading">
          <h2>Formats likely to scale</h2>
          <span>Model forecast</span>
        </div>
        <% dashboard.contentTypes.forEach((item) => { %>
          <div class="score-row large">
            <div>
              <strong><%= item.name %></strong>
              <small>Expected reach: <%= item.reach %></small>
            </div>
            <span><%= item.score %></span>
          </div>
        <% }) %>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <h2>Trending audio shelf</h2>
          <span>Reusable ideas</span>
        </div>
        <% dashboard.audios.forEach((audio) => { %>
          <div class="audio-card slim">
            <strong><%= audio.name %></strong>
            <span><%= audio.vibe %></span>
            <small><%= audio.bpm %> BPM · <%= audio.lift %> discovery lift</small>
          </div>
        <% }) %>
      </article>
    </section>
  </section>
</main>
<%- include('partials/footer') %>
